                                <!-- ── Right: canvas + chain code labels below ──────────────────── -->
                                <item>
                                    <widget class="QWidget" name="snakeViewWidget" native="true">
                                        <property name="sizePolicy">
                                            <sizepolicy hsizetype="Expanding" vsizetype="Expanding">
                                                <horstretch>1</horstretch><verstretch>1</verstretch>
                                            </sizepolicy>
                                        </property>
                                        <layout class="QVBoxLayout" name="layoutSnakeView">

                                            <!-- Canvas -->
                                            <item>
                                                <widget class="QLabel" name="snakeCanvasHost">
                                                    <property name="sizePolicy">
                                                        <sizepolicy hsizetype="Expanding" vsizetype="Expanding">
                                                            <horstretch>1</horstretch><verstretch>1</verstretch>
